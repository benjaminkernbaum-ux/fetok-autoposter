# ───────────────────────────────────────────────
# FéTok Autoposter — Environment Variables
# Copy to .env and fill in. Never commit .env.
# ───────────────────────────────────────────────

# --- Cinematic Pipeline (Higgsfield + MJ + ElevenLabs) ---

# Midjourney via ImagineAPI (or useapi.net wrapper)
MIDJOURNEY_API_KEY=
MIDJOURNEY_ENDPOINT=https://api.imagineapi.dev/items/images/

# Higgsfield DoP I2V
HIGGSFIELD_API_KEY=
HIGGSFIELD_ENDPOINT=https://api.higgsfield.ai/v1

# ElevenLabs (PT-BR narration)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- Publishing (existing) ---

# TikTok Business (optional — manual upload if empty)
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# Meta / Instagram Reels (optional)
META_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=

# Discord / Slack webhook (notifications)
WEBHOOK_URL=

# --- Soul ID (character consistency) ---
# Replicate API for optional face similarity validation
REPLICATE_API_TOKEN=
# Base URL where keyframes are publicly served (for MJ --cref/--sref)
SOUL_REF_BASE_URL=

# --- Cinematic weekly scheduler ---
# Enable only after MJ + HF + ElevenLabs keys are set and tested manually.
CINEMATIC_ENABLED=false
# Default: Sun 23:00 UTC (= Sun 20:00 BRT). Override freely.
CINEMATIC_CRON=0 23 * * 0
# Required by Meta Reels (MP4 must be publicly fetchable)
PUBLIC_BASE_URL=

# --- Server ---
PORT=3000
